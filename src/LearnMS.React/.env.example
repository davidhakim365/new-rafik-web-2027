# API origin for Capacitor / production mobile builds (no trailing slash).
# Leave empty for web/dev so Vite's /api proxy is used.
# Example: VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=

# Dev-only: Vite proxy target for /api (default http://localhost:5000)
# VITE_API_PROXY=http://localhost:5000
